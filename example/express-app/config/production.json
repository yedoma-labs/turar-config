{
  "server": {
    "port": 8080,
    "host": "0.0.0.0"
  },
  "cors": {
    "origins": ["https://app.example.com"]
  },
  "database": {
    "host": "${DB_HOST}",
    "port": 5432,
    "name": "${DB_NAME}",
    "pool": {
      "min": 5,
      "max": 100
    }
  },
  "redis": {
    "url": "${REDIS_URL}"
  },
  "features": {
    "enableMetrics": true,
    "enableDebugMode": false
  }
}
