{
  "name": "@yedoma-labs/turar-config",
  "version": "0.2.0",
  "description": "Type-safe configuration management with file loading, environment cascading, and secrets integration - extends bylyt-env-guard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "config",
    "configuration",
    "environment",
    "env",
    "validation",
    "type-safe",
    "typescript",
    "cascade",
    "cascading",
    "secrets",
    "json",
    "dotenv",
    "node-config",
    "convict",
    "12factor",
    "settings",
    "multi-environment",
    "interpolation",
    "vault",
    "bylyt",
    "schema",
    "zero-dependency"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yedoma-labs/turar-config"
  },
  "homepage": "https://github.com/yedoma-labs/turar-config#readme",
  "bugs": {
    "url": "https://github.com/yedoma-labs/turar-config/issues"
  },
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@yedoma-labs/bylyt-env-guard": "^0.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@yedoma-labs/bylyt-env-guard": "^0.3.5",
    "tsdown": "^0.22.2",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chokidar": "^3.6.0",
    "node-vault": "^0.12.0",
    "yaml": "^2.9.0"
  }
}
